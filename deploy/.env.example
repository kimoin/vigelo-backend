# Copy to deploy/.env on the VSRV server. deploy/.env is git-ignored.
# Generate secrets: ./scripts/generate-secrets.sh

# --- Postgres (internal) ---
POSTGRES_DB=vsrv
POSTGRES_USER=vsrv
POSTGRES_PASSWORD=change-me

# --- Public API (Caddy + Let's Encrypt) ---
VSRV_HOSTNAME=api.example.vigelo.fi
VSRV_PUBLIC_URL=https://api.example.vigelo.fi
FRONTEND_BASE_URL=https://app.example.vigelo.fi
VSRV_CORS_ORIGIN=https://app.example.vigelo.fi
VSRV_LOG_LEVEL=info

# --- Admin console (/admin/) ---
VSRV_ADMIN_EMAILS=you@example.com
VSRV_AUDIT_RETENTION_DAYS=60

# --- VNMS (separate UpCloud VM, private network) ---
# Use the VNMS VM private IP, e.g. http://10.0.1.10:8080
# Must match VNMS_HTTP_TOKEN on the VNMS server (same value in both .env files).
VNMS_BASE_URL=http://10.0.1.10:8080
VNMS_HTTP_TOKEN=change-me-shared-with-vnms
# For HTTPS to VNMS with a private CA, place ca.pem in deploy/certs/ and set:
# VNMS_TLS_CA=/certs/ca.pem
# VNMS_BASE_URL=https://10.0.1.10:8443

# --- Email (MailerSend) ---
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=notify@vigelo.fi
MAILERSEND_FROM_NAME=Vigelo

# --- SMS (GatewayAPI) — leave empty to log only ---
GATEWAYAPI_TOKEN=
GATEWAYAPI_SENDER=Vigelo

# --- Push ---
PUSH_PROVIDER=log
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOKEN=

# --- Device / trial policy ---
OFFLINE_THRESHOLD_HOURS=3
DEFAULT_TRIAL_DAYS=30

# --- Session TTLs (optional overrides) ---
# VSRV_ACCESS_TOKEN_TTL_HOURS=1
# VSRV_REFRESH_TOKEN_TTL_DAYS=30
# VSRV_INVITE_TTL_DAYS=7
